<RT3>
    <lookat look_from="0 4.5 -15" look_at="0 0 1" up="0 1 0" />
    <camera type="perspective" fovy="45" /> 
    <integrator type="toon" mapping_interval="5 45 65 75 85" n_intervals="5" />
    <film type="image" w_res="1920" h_res="1200" filename="all_lights.png" img_type="png" gamma_corrected="true" />

    <!-- Objects storage -->
    <aggregator type="list"/>

    <!-- The Scene -->
    <world_begin/>

        <!-- The Background -->
        <background type="4_colors" bl="176 214 175" tl="4 99 202" tr="4 99 202" br="176 214 175" />

        <!-- Lights -->
        <light_source type="ambient" I="0.1 0.1 0.1" scale="0.5 0.5 0.5" />
        <light_source type="directional" I="0.9 0.9 0.9" scale="0.4 0.4 0.4" from="1 0.8 -1" to="0 0 1" world_radius="50" />
        <light_source type="point" I="0.95 0.9 0.8" scale="0.4 0.4 0.4" from="0.1 3.0 1" />

        <!-- Material Library -->
        <make_named_material type="toon" name="gold"     color_map="0 0 0 45 30 0  95 65 5  165 115 10  235 180 15  255 230 110"/>
        <make_named_material type="toon" name="grey"     color_map="25 25 25  60 60 60  110 110 110  170 170 170  230 230 230"/>
        <make_named_material type="toon" name="redish"   color_map="0 0 0 50 5 10  120 10 20  190 20 30  240 60 65  255 160 165"/>
        <make_named_material type="toon" name="greenish" color_map="0 0 0 5 30 10  20 75 25  45 140 50  90 200 95  180 245 185"/>
        <make_named_material type="toon" name="blueish"  color_map="0 0 0 5 15 40  15 40 100  30 85 180  70 150 235  165 220 255"/>
        <make_named_material type="toon" name="plane"    color_map="25 25 25  60 60 60  110 110 110  170 170 170  230 230 230"/>

        <!-- Objects -->
        <named_material name="redish"/>
        <object type="sphere" center="0 1 0" radius="1" />

        <named_material name="greenish"/>
        <object type="sphere" center="-5 1 4" radius="1" />

        <named_material name="blueish"/>
        <object type="sphere" center="2 1 5" radius="1" />

        <named_material name="gold"/>
        <object type="sphere" center="5 3.1 -1" radius="1.3" />

        <named_material name="grey"/>
        <object type="plane" point="0 0 0" normal="0 1 0" />
        <!-- <object type="sphere" center="0 -5000 0" radius="5000" /> -->

    <world_end/>
</RT3>
