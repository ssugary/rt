<RT3>
    <!-- Look from ABOVE the plane -->
    <lookat look_from="8 11 -9" look_at="0 1 0" up="0 1 0" /> 
    <camera type="perspective" fovy="45" />
    <integrator type="blinn_phong" depth="2" />
    <!-- Objects storage -->
    <aggregator type="list"/>

    <film type="image" w_res="1920" h_res="1080" filename="3_spheres_plane_below.png" img_type="png" gamma_corrected="false" />
    <!-- The Scene -->
    <world_begin/>

        <!-- The Background -->
        <background type="single_color" color="220 220 220"/>
        <!-- Lights -->
        <light_source type="directional" I="0.9 0.9 0.9" scale="0.8 0.8 0.8" from="3 2.8 -2" to="0 0 1" />
        <light_source type="directional" I="0.9 0.9 0.9" scale="0.8 0.8 0.8" from="-5 5.2 -4" to="-1 0 3" />
        <!-- Material Library -->
        <make_named_material type="blinn" name="redish"   ambient="0.6 0.6 0.6" diffuse ="0.74 0.13 0.12" specular ="0.8 0.8 0.8"  glossiness ="64"/>
        <make_named_material type="blinn" name="yellow"   ambient="0.4 0.4 0.4" diffuse ="0.95 0.65 0.07" specular ="0.8 0.6 0.2"  glossiness ="256"/>
        <make_named_material type="blinn" name="blueish"  ambient="0.4 0.4 0.4" diffuse ="0.16 0.2 0.36"  specular ="0.8 0.8 0.8"  glossiness ="256"/>
        <make_named_material type="blinn" name="green"    ambient="0.6 0.6 0.6" diffuse ="0.52 0.7 0.33"  specular ="0.8 0.8 0.8"  mirror="0.7 0.7 0.7" glossiness ="128"/>
        <make_named_material type="blinn" name="salmon"   ambient="0.6 0.6 0.6" diffuse ="1.0 0.64 0.68"  specular ="0.8 0.8 0.8"  mirror="0.7 0.7 0.7" glossiness ="128"/>

        <!-- Objects -->
        <named_material name="redish"/>
        <object type="sphere" radius="1" center="0 1 1"/>

        <named_material name="yellow"/>
        <object type="sphere" radius="1" center="-2 1 -2" />

        <named_material name="blueish"/>
        <object type="sphere" radius="1" center="2 1 -2" />

        <named_material name="green"/>
        <object type="trianglemesh"
            ntriangles ="2"
            vertices ="-6 0 4  6 0 4  6 0 -4  -6 0 -4"
            vertex_indices ="0 1 2  0 2 3"
            normals ="0 1 0"
            normal_indices ="0 0 0  0 0 0"
            reverse_vertex_order="false"
            backface_cull ="true"/>
   <world_end/>
</RT3>
